# Google Maps API Key (optional, for embedded maps)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# Google Search Console Verification
NEXT_PUBLIC_GOOGLE_VERIFICATION=your_google_verification_code_here

# Form Submission Endpoint (optional, if using external service)
NEXT_PUBLIC_FORM_ENDPOINT=https://your-form-endpoint.com/submit

# Vercel Environment
NEXT_PUBLIC_VERCEL_URL=https://alcanroofing.com
NODE_ENV=production
